# shellcheck disable=SC2148
# shellcheck disable=SC2034

# LLM providers (fallback order: groq -> deepseek -> mistral -> openai).
# At least one is required; missing providers are skipped.
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
MISTRAL_API_KEY=...
OPENAI_API_KEY=sk-proj-...

# Google Sheets
GOOGLE_SHEETS_CLIENT_EMAIL=...
GOOGLE_SHEETS_PRIVATE_KEY=...
GOOGLE_SHEETS_SPREADSHEET_ID=...

# Optional: override the sheet tab name (defaults to "Transactions").
# The Jest suite sets this to "Test" automatically.
# GOOGLE_SHEETS_TRANSACTIONS_SHEET_NAME=Transactions
